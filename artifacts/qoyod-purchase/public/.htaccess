RewriteEngine On

# Let requests under ./api/ pass through untouched (handled by its own .htaccess),
# regardless of whether this app is deployed at the domain root or a subfolder.
RewriteRule ^api/ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
